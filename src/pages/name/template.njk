{% extends "../../template/page.njk" %}
{% block goBack %}
    {{ backLink({
    href: getRequestUri(),
    text: t("common.back")
  }) }}
{% endblock %}
{% block content %}
    <h1>{{ title }}
    </h1>
    <form action="{{ getRequestUri('name') }}" method="post">
        {% if error %}
            {{ errorSummary({
        titleText: t("error.summaryTitle"),
        errorList: error.errorList
      }) }}
        {% endif %}
        {% set firstNameErrorMessage = { 
      text: t(error.fields.firstName) 
    } if error.fields.firstName else null %}
        {{ input({
      label: {
        text: t("name.firstNameLabel")
      },
      id: "firstName",
      name: "firstName",
      classes: "nhsuk-input--error" if error.fields.firstName else "",
      errorMessage: firstNameErrorMessage,
      value: body.firstName | d('')
    }) }}
        {% set lastNameErrorMessage = { 
      text: t(error.fields.lastName) 
    } if error.fields.lastName else null %}
        {{ input({
      label: {
        text: t("name.lastNameLabel")
      },
      id: "lastName",
      name: "lastName",
      classes: "nhsuk-input--error" if error.fields.lastName else "",
      errorMessage: lastNameErrorMessage,
      value: body.lastName | d('')
    }) }}
        {{ button({
      text: t("common.continue")
    }) }}
    </form>
{% endblock %}